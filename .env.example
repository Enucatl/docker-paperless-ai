# paperless-ai — environment variable reference
# Copy to .env and fill in your values.

# =============================================================================
# Database / Paperless-ngx
# =============================================================================

# Secret key — generate with: openssl rand -hex 32
PAPERLESS_SECRET_KEY=

# Database password
POSTGRES_PASSWORD=paperless
PAPERLESS_DBPASS=paperless

# Your domain (used by Traefik routing and PAPERLESS_URL)
DOCKER_DOMAIN=example.com

# Timezone — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
PAPERLESS_TIME_ZONE=Europe/Zurich

# OCR language(s) — see tesseract-ocr language codes
PAPERLESS_OCR_LANGUAGE=deu

# Optional: extra Tesseract args, for example:
# PAPERLESS_OCR_USER_ARGS={"invalidate_digital_signatures": true, "continue_on_soft_render_error": true}
# PAPERLESS_OCR_USER_ARGS=

# UID/GID of the host user that owns the consume directory
USERMAP_UID=1000
USERMAP_GID=1000

# Paperless API token — get from: Settings → API Tokens in the UI
PAPERLESS_TOKEN=

# =============================================================================
# Search / Embeddings
# =============================================================================

# Embedding API server (OpenAI-compatible endpoint, e.g. vLLM)
# EMBEDDING_API_BASE=http://workstation:8102/v1
EMBEDDING_API_BASE=
EMBEDDING_MODEL=BAAI/bge-m3

# Optional LLM-based chunk situating for contextual retrieval
# SITUATION_MODEL=gemini/gemini-2.5-flash
# SITUATION_API_BASE=http://workstation:8103/v1
# SITUATION_TEMPERATURE=0.0
# SITUATION_MAX_TOKENS=200
# SITUATION_CONTEXT_CHARS=0

# =============================================================================
# OCR
# =============================================================================

# Any LiteLLM vision model string. Examples:
#   gemini/gemini-2.5-flash          (cloud, default — requires GOOGLE_API_KEY)
#   claude-3-5-sonnet-20241022       (cloud — requires ANTHROPIC_API_KEY)
#   gpt-4o                           (cloud — requires OPENAI_API_KEY)
#   openai/nanonets/Nanonets-OCR2-3B (local vLLM — set OCR_API_BASE)
#   ollama/llava-llama3              (local Ollama — set OCR_API_BASE)
OCR_MODEL=gemini/gemini-2.5-flash

# Base URL for a self-hosted OCR model server (Ollama or vLLM).
# Examples:
#   OCR_API_BASE=http://workstation:11434
#   OCR_API_BASE=http://workstation:8100/v1
# OCR_API_BASE=

# OCR generation settings
# OCR_TEMPERATURE=0.0
# OCR_REASONING_EFFORT=minimal
# OCR_EXTRA_KWARGS={"top_p": 0.95}

# =============================================================================
# Metadata Extraction
# =============================================================================

# Text-only model for title/date/correspondent extraction (called once per doc).
#   gemini/gemini-2.5-flash
#   openai/meta-llama/Llama-3.2-3B-Instruct   (local vLLM — set METADATA_API_BASE)
#   ollama/llama3.2                            (local Ollama — set METADATA_API_BASE)
METADATA_MODEL=gemini/gemini-2.5-flash

# Base URL for a self-hosted metadata model server.
# Examples:
#   METADATA_API_BASE=http://workstation:11434
#   METADATA_API_BASE=http://workstation:8101/v1
# METADATA_API_BASE=

# Metadata generation settings
# METADATA_TEMPERATURE=0.2
# METADATA_REASONING_EFFORT=minimal
# METADATA_MAX_TOKENS=1000
# METADATA_EXTRA_KWARGS={"top_p": 0.95}

# =============================================================================
# Chat
# =============================================================================

# Chat model for the browser copilot. Set this explicitly; it does not fall
# back to METADATA_MODEL.
CHAT_MODEL=gemini/gemini-2.5-flash

# Base URL for a self-hosted chat model server.
# Examples:
#   CHAT_API_BASE=http://workstation:11434
#   CHAT_API_BASE=http://workstation:8102/v1
# CHAT_API_BASE=

# Chat generation settings
# CHAT_TEMPERATURE=0.2
# CHAT_REASONING_EFFORT=minimal
# CHAT_MAX_TOKENS=1000
# CHAT_EXTRA_KWARGS={"top_p": 0.95}

# =============================================================================
# API Keys
# =============================================================================

GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# HuggingFace token — required for gated models (e.g. Llama) on the workstation
# HF_TOKEN=

# =============================================================================
# Runtime
# =============================================================================

# Seconds between polls in watch mode
# POLL_INTERVAL=300

# Max documents processed concurrently per batch (increase for cloud models like Gemini,
# keep at 1-2 for local vLLM which handles its own continuous batching)
# OCR_CONCURRENCY=4

# Tag name (must match what you configure in Paperless Workflows)
# TAG_PENDING=ai-review-pending

# Set to true to log actions without modifying any documents
# DRY_RUN=false

# =============================================================================
# Webhook Listener / Security
# =============================================================================

# Secret token for validating webhook requests from Paperless.
# If unset, the webhook endpoint is unauthenticated (suitable for private networks).
# Generate with: openssl rand -hex 32
# WEBHOOK_SECRET=
