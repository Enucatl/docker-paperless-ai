%%{init: {"flowchart": {"defaultRenderer": "elk"}} }%%
%% Data ingestion architecture source for docs/portfolio/assets/data-ingestion-flow.png.
%% Local GPU model serving is handled outside this repo by:
%% https://github.com/Enucatl/docker-vllm

flowchart TB
  paperless_workflow["paperless-ngx workflows"]
  listener["webhook-listener"]
  redis["redis"]
  worker["AI worker<br/>waits for GPU workstation"]

  subgraph models["Model calls"]
    direction LR
    ocr["OCR model<br/>Nanonets-OCR2-3B"]
    metadata["Metadata model<br/>gemini 3.1 flash-lite"]
    embedding["Embedding model<br/>BAAI/bge-m3"]
  end

  subgraph sinks["State updates and observability"]
    direction LR
    paperless_api["paperless-ngx<br/>REST API"]
    qdrant["qdrant<br/>vector DB"]
    phoenix["arize phoenix<br/>traces + token/cost"]
  end

  paperless_workflow -- "doc added<br/>doc updated" --> listener
  listener -- "doc id" --> redis
  redis -- "stage queues" --> worker

  worker -- "ai:run-ocr<br/>page images" --> ocr
  worker -- "ai:run-metadata" --> metadata
  worker -- "ai:run-embed" --> embedding

  ocr -- "transcription" --> metadata
  metadata -- "chunks with metadata" --> embedding

  ocr -- "content" --> paperless_api
  metadata -- "metadata" --> paperless_api
  embedding -- "embedded vectors" --> qdrant

  ocr -. "trace" .-> phoenix
  metadata -. "trace" .-> phoenix
  embedding -. "trace" .-> phoenix

  subgraph legend["Legend"]
    legend_upstream["upstream<br/>paperless stack"]
    legend_stack["this repo<br/>container"]
    legend_local["local model"]
    legend_cloud["cloud model"]
  end
  legend_upstream ~~~ legend_stack
  legend_stack ~~~ legend_local
  legend_local ~~~ legend_cloud
  legend_stack ~~~ paperless_workflow

  classDef stack fill:#d9ecff,stroke:#2f6f9f,stroke-width:1px,color:#111;
  classDef upstream fill:#8fbbe8,stroke:#1f4f78,stroke-width:1px,color:#111;
  classDef localModel fill:#e2f5dc,stroke:#3f7f3f,stroke-width:1px,color:#111;
  classDef cloudModel fill:#9fd08f,stroke:#2f6f2f,stroke-width:1px,color:#111;

  class listener,worker,qdrant,phoenix stack;
  class paperless_workflow,paperless_api,redis upstream;
  class ocr,embedding localModel;
  class metadata cloudModel;
  class legend_stack stack;
  class legend_upstream upstream;
  class legend_local localModel;
  class legend_cloud cloudModel;
