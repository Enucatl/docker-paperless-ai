%%{init: {"flowchart": {"defaultRenderer": "elk"}} }%%
%% Agentic chat architecture source for docs/portfolio/assets/agentic-chat-flow.png.

flowchart TB
  user["User query"]
  agent["LangGraph chat agent<br/>Gemini 3.1 flash-lite"]
  response["Source-backed response<br/>returned to user"]

  subgraph tools["Agent tools"]
    direction LR
    get_metadata["get_available_metadata"]
    read_full["read_full_document"]
    hybrid["hybrid_search"]
  end

  paperless_api["paperless-ngx REST API<br/>metadata + full document text"]

  subgraph hybrid_pipeline["Hybrid search pipeline"]
    direction TB
    keyword["keyword search<br/>Paperless / Postgres"]
    vector["dense vector search<br/>Qdrant"]
    fusion["Reciprocal Rank Fusion<br/>combine result lists"]
    reranker["local reranker<br/>BAAI/bge-reranker-v2-m3"]
    judge["LLM precision judge<br/>Gemini 3.1 flash-lite"]
    search_result["ranked source candidates"]
  end

  qdrant["Qdrant<br/>document chunk vectors"]
  query_embedder["CPU query embedder<br/>BAAI/bge-m3<br/>loads/unloads RAM"]
  phoenix["Arize Phoenix<br/>tool spans + LLM traces<br/>token/cost visibility"]

  user --> agent
  agent --> tools
  tools --> get_metadata
  tools --> read_full
  tools --> hybrid

  get_metadata --> paperless_api
  read_full --> paperless_api
  paperless_api --> agent

  hybrid --> keyword
  hybrid --> query_embedder --> vector
  keyword --> paperless_api
  vector --> qdrant
  keyword --> fusion
  vector --> fusion
  fusion --> reranker --> judge --> search_result --> agent

  agent --> response

  agent -. "chat + tool + LLM traces" .-> phoenix

  classDef stack fill:#d9ecff,stroke:#2f6f9f,stroke-width:1px,color:#111;
  classDef upstream fill:#8fbbe8,stroke:#1f4f78,stroke-width:1px,color:#111;
  classDef localModel fill:#e2f5dc,stroke:#3f7f3f,stroke-width:1px,color:#111;
  classDef cloudModel fill:#9fd08f,stroke:#2f6f2f,stroke-width:1px,color:#111;
  classDef userNode fill:#f4edff,stroke:#7253a3,stroke-width:1px,color:#111;

  class agent,hybrid,get_metadata,read_full,qdrant,phoenix stack;
  class paperless_api,keyword upstream;
  class query_embedder,vector,reranker localModel;
  class judge cloudModel;
  class user,response,tools,fusion,search_result userNode;
